{
  "name": "react-component-jump",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.cjs",
      "require": "./dist/client.cjs"
    },
    "./babel": {
      "types": "./dist/babel.d.ts",
      "import": "./dist/babel.cjs",
      "require": "./dist/babel.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.cts",
      "require": "./dist/webpack.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "tsup",
    "deploy": "npm run build:lib && npm pack --dry-run --cache .npm-cache && npm publish --access public --cache .npm-cache --otp=$npm_config_otp",
    "prepublishOnly": "npm run build:lib",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@babel/core": ">=7",
    "@vitejs/plugin-react": ">=4"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
