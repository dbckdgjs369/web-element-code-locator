{
  "name": "react-code-locator",
  "version": "0.1.18",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "tsup",
    "deploy": "npm run build:lib && npm pack --dry-run --cache .npm-cache && npm publish --access public --cache .npm-cache --otp=$npm_config_otp",
    "prepublishOnly": "npm run build:lib",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "astring": "^1.9.0"
  },
  "peerDependencies": {
    "unplugin": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "unplugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/node": "^22.13.10",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "unplugin": "^3.0.0",
    "vite": "^5.4.14"
  }
}
