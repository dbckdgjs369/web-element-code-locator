{
  "name": "react-code-locator",
  "version": "0.1.15",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "react-code-locator-mcp": "./dist/mcpCli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./babel": {
      "types": "./dist/babel.d.ts",
      "import": "./dist/babel.js",
      "require": "./dist/babel.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js",
      "require": "./dist/esbuild.cjs"
    },
    "./swc": {
      "types": "./dist/swc.d.ts",
      "import": "./dist/swc.js",
      "require": "./dist/swc.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.cts",
      "require": "./dist/webpack.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib",
    "build:lib": "tsup",
    "deploy": "npm run build:lib && npm pack --dry-run --cache .npm-cache && npm publish --access public --cache .npm-cache --otp=$npm_config_otp",
    "prepublishOnly": "npm run build:lib",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@babel/core": ">=7"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.13.10",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
