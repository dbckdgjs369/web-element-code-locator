{
  "name": "react-code-locator",
  "version": "0.3.11",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/runtime.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dbckdgjs369/web-element-code-locator.git"
  },
  "homepage": "https://github.com/dbckdgjs369/web-element-code-locator#readme",
  "bugs": {
    "url": "https://github.com/dbckdgjs369/web-element-code-locator/issues"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:copy-loaders && npm run build:patch-loaders",
    "build:lib": "tsup",
    "build:copy-loaders": "node -e \"const fs=require('fs');const path=require('path');['webpack','rspack'].forEach(t=>{const src=path.join('node_modules/unplugin/dist',t,'loaders');const dst=path.join('dist',t,'loaders');fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>{fs.copyFileSync(path.join(src,f),path.join(dst,f));if(f.endsWith('.js')){fs.copyFileSync(path.join(src,f),path.join(dst,f.replace(/\\.js$/,'.cjs')))}})})\"",
    "build:patch-loaders": "node scripts/patch-loaders.cjs",
    "deploy": "npm run build && npm pack --dry-run --cache .npm-cache && npm publish --access public --cache .npm-cache --otp=$npm_config_otp",
    "release:patch": "npm version patch && npm run build && npm publish --access public --otp=$npm_config_otp",
    "release:minor": "npm version minor && npm run build && npm publish --access public --otp=$npm_config_otp",
    "release:major": "npm version major && npm run build && npm publish --access public --otp=$npm_config_otp",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "@types/node": "^22.13.10",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "acorn-typescript": "^1.4.13",
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "unplugin": "^3.0.0",
    "vite": "^5.4.14"
  }
}
